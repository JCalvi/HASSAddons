{
  "name": "Rekognition Bridge",
  "version": "2026.3.10",
  "slug": "hass-rekognition",
  "init": false,
  "description": "Bridges local snapshots to AWS Rekognition for facial recognition and exposes an HTTP API returning match results.",
  "url": "https://github.com/JCalvi/HASSAddons/tree/master/hass-rekognition",
  "image": "jcrfc/hass-rekognition-{arch}",
  "arch": ["aarch64", "amd64"],
  "startup": "application",
  "boot": "auto",
  "ports": {
    "8080/tcp": 8080
  },
  "map": ["media:ro"],
  "options": {
    "aws_access_key_id": "",
    "aws_secret_access_key": "",
    "aws_region": "ap-southeast-2",
    "rekognition_collection": "ha_known_people",
    "s3_bucket": "user-ha-rekognition-staging-accountnumber",
    "s3_prefix": "snapshots/",
    "default_threshold": 95,
    "delete_after_match": true,
    "ha_url": "http://172.30.32.1:8123",
    "ha_token": "",
    "helper_person_name": "",
    "helper_person_similarity": "",
    "helper_person_status": "",
    "worker_timeout": 60,
    "log_worker_stderr": false,
    "api_token": "",
    "log_level": "INFO"
  },
  "schema": {
    "aws_access_key_id": "str",
    "aws_secret_access_key": "password",
    "aws_region": "str",
    "rekognition_collection": "str",
    "s3_bucket": "str",
    "s3_prefix": "str",
    "default_threshold": "int(1,100)",
    "delete_after_match": "bool",
    "ha_url": "str",
    "ha_token": "str",
    "helper_person_name": "str",
    "helper_person_similarity": "str",
    "helper_person_status": "str",
    "worker_timeout": "int(1,600)",
    "log_worker_stderr": "bool",
    "api_token": "password",
	"log_level": "list(TRACE|DEBUG|INFO|WARNING|ERROR|CRITICAL)"
  }
}
